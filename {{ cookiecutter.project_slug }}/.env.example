# Application
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

# CORS (JSON list of allowed origins)
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database (prod: postgresql+asyncpg://user:password@localhost:5432/dbname)
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# JWT — must change JWT_SECRET in production (set APP_DEBUG=false to enforce)
JWT_SECRET=change-this-in-production
JWT_EXPIRATION_DAYS=90
JWT_ALGORITHM=HS256
